      "type": "string",
      "label": "天気図名"
    },
    "targetDateTime": {
      "type": "string",
      "label": "対象時刻 (ISO)"
    },
    "validDateTime": {
      "type": "string",
      "label": "有効時刻 (ISO)"
    },
    "pngFilename": {
      "type": "string",
      "label": "PNG ファイル名"
    },
    "pngUrl": {
      "type": "string",
